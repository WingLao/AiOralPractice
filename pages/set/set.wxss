page {
  height: 100%; 
  overflow: hidden; 
  background-color: #f8faff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  display: flex; 
  flex-direction: column; 
  height: 100vh;
  box-sizing: border-box; 
  padding: 20rpx;
}

.header {
  position: relative; 
  display: flex;
  justify-content: center; 
  align-items: center;
  /* Changed from fixed height to auto to allow text wrapping */
  height: auto; 
  min-height: 140rpx;
  padding: 20rpx 0; 
  margin-bottom: 20rpx; 
  flex-shrink: 0;
}

.back-btn {
  position: absolute; 
  left: 10rpx; 
  top: 50%;
  transform: translateY(-50%);
  width: 70rpx; 
  height: 70rpx;
  border-radius: 50%; 
  background-color: white;
  display: flex; 
  justify-content: center; 
  align-items: center;
  box-shadow: 0 6rpx 16rpx rgba(59, 102, 255, 0.15);
  font-size: 36rpx; 
  color: #3b66ff;
  padding-bottom: 4rpx; 
}

/* Wrapper for Title + Subtitle */
.title-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 70%; /* Limit width to prevent hitting back button */
}

.title {
  font-size: 60rpx; 
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1;
  text-align: center;
}

.set-subtitle {
  font-size: 42rpx;       /* Increased size ~40 */
  color: #1a1a1a; 
  font-weight: 800; 
  margin-top: 12rpx;
  text-align: center;
  width: 100%;
  
  /* Logic for wrapping instead of dots */
  white-space: normal;    /* Allows text to wrap to next line */
  line-height: 1.2;       /* Good spacing for multi-line */
  overflow: visible;      /* Show all text */
  display: block;
}

.content-area {
  flex: 1; 
  display: flex; 
  flex-direction: column;
  justify-content: center; 
  align-items: center;
  width: 100%;
  /* Extra bottom padding to visually center the Start button area */
  padding-bottom: 200rpx;
}

.prepare-text {
  font-size: 38rpx; 
  color: #3b66ff; 
  font-weight: 800;
  text-align: center; 
  margin-bottom: 80rpx; 
  line-height: 1.6; 
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.big-start-btn {
  width: 280rpx; 
  height: 280rpx; 
  border-radius: 50%;
  background-color: #3b66ff; 
  color: white;
  display: flex; 
  justify-content: center; 
  align-items: center;
  font-size: 48rpx; 
  font-weight: 800; 
  text-transform: uppercase;
  box-shadow: 0 15rpx 40rpx rgba(59, 102, 255, 0.3);
  letter-spacing: 2rpx;
}

.context-box {
  background-color: white; 
  width: 90%; 
  padding: 40rpx;
  border-radius: 30rpx; 
  box-shadow: 0 10rpx 40rpx rgba(59, 102, 255, 0.1);
  color: #5c78b5; 
  font-size: 30rpx; 
  font-weight: 500; 
  line-height: 1.6; 
  text-align: left;
}

.context-heading, .role-line {
  color: #3b66ff; font-size: 32rpx; margin-top: 20rpx;
  margin-bottom: 10rpx; font-weight: bold;
}
.roles-section { border-bottom: 1px solid #eee; padding-bottom: 20rpx; margin-bottom: 20rpx; }
.task-list { padding-left: 20rpx; }

.timer-display {
  font-size: 70rpx; 
  font-weight: 800; color: #3b66ff;
  margin-top: 40rpx; font-variant-numeric: tabular-nums;
}

/* Add Skip Button Styles */
.skip-btn {
  margin-top: 50rpx; 
  width: 200rpx;          /* Matches the DONE button width */
  height: 140rpx;         /* Matches the DONE button height */
  background-color: #3b66ff; /* Solid blue background */
  color: white; 
  border-radius: 30rpx;   /* Rounded corners */
  font-size: 28rpx; 
  font-weight: 800;       /* Extra bold text */
  display: flex; 
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(59, 102, 255, 0.25); /* Soft blue drop shadow */
  text-transform: uppercase; /* Capitalizes to SKIP */
  text-align: center;
  letter-spacing: 2rpx;
  transition: all 0.1s ease;
}

.skip-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}